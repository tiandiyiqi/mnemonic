{
  "name": "mnemonic-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI for managing AI agent skills - install, list, and remove skills from any coding agent",
  "keywords": [
    "cli",
    "skills",
    "agent",
    "ai",
    "claude",
    "cursor",
    "trae",
    "codex",
    "memory",
    "mnemonic"
  ],
  "author": "baobaozhu",
  "license": "MIT",
  "homepage": "https://github.com/baobaozhu/mnemonic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baobaozhu/mnemonic.git"
  },
  "bugs": {
    "url": "https://github.com/baobaozhu/mnemonic/issues"
  },
  "bin": {
    "mnemonic": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
